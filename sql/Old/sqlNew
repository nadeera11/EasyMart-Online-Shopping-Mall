-- 1. User Table (For Customers and Sellers)
CREATE TABLE 'User' (
    user_id INT AUTO_INCREMENT PRIMARY KEY,
    firstName VARCHAR(50),
    lastName VARCHAR(50),
    email VARCHAR(100),
    password VARCHAR(255),
    phone_number VARCHAR(15),
    address TEXT,
    account_type ENUM('customer', 'seller')  -- Differentiates between customer and seller
);

-- 2. Admin Table (Separate for Admins)
CREATE TABLE 'Admin' (
    admin_id INT AUTO_INCREMENT PRIMARY KEY,
    firstName VARCHAR(50),
    lastName VARCHAR(50),
    password VARCHAR(255)
);

-- 3. Order Table (For Sellers and Customers)
CREATE TABLE 'Order' (
    orderid INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,  -- Foreign key to User (Customer ID)
    sellerid INT,  -- Foreign key to User (Seller ID)
    product_id INT,  -- Foreign key to Product
    DATE DATETIME,
    address TEXT,
    payment_method ENUM('credit_card', 'paypal', 'cash_on_delivery'),
    price DECIMAL(10, 2),
    status ENUM('pending', 'shipped', 'delivered', 'canceled'),
    FOREIGN KEY (user_id) REFERENCES 'User'(user_id) ON DELETE CASCADE,
    FOREIGN KEY (sellerid) REFERENCES 'User'(user_id) ON DELETE CASCADE
);

-- 4. Product Table (For Sellers)
CREATE TABLE 'Product' (
    productid INT AUTO_INCREMENT PRIMARY KEY,
    sellerid INT,  -- Foreign key to User (Seller ID)
    name VARCHAR(100),
    description TEXT,
    price DECIMAL(10, 2),
    image VARCHAR(255),
    category VARCHAR(50),
    FOREIGN KEY (sellerid) REFERENCES 'User'(user_id) ON DELETE CASCADE
);

-- 5. Discount Table (For Sellers)
CREATE TABLE 'Discount' (
    discountid INT AUTO_INCREMENT PRIMARY KEY,
    sellerid INT,  -- Foreign key to User (Seller ID)
    description TEXT,
    discount_code VARCHAR(50),
    FOREIGN KEY (sellerid) REFERENCES 'User'(user_id) ON DELETE CASCADE
);

-- 6. Inquiry Table (For Customers and Admins)
CREATE TABLE 'Inquiry' (
    inquiry_id INT AUTO_INCREMENT PRIMARY KEY,
    user_id INT,  -- Foreign key to User (Customer ID)
    description TEXT,
    DATE DATE,
    status ENUM('open', 'closed'),
    FOREIGN KEY (user_id) REFERENCES 'User'(user_id) ON DELETE CASCADE
);




